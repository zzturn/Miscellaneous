    {
      "description": "✦ Hyper: 选中",
      "manipulators": [
        {"description": "Hyper + ⇧H: 选左","type": "basic","from": {"key_code": "h","modifiers": {"mandatory": ["shift"]}},"to": [{"key_code": "left_arrow","modifiers": ["left_shift"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
