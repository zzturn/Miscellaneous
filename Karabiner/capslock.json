  "rules": [
    {
      "description": "⌨ Hyper: 激活",
      "manipulators": [
        {"description": "CapsLock: 按住激活，单击 Esc","type": "basic","from": {"key_code": "caps_lock","modifiers": {"optional": ["any"]}},"to": [{"set_variable": {"name": "hyper_on","value": 1,"key_up_value": 0}}],"to_if_alone": [{"key_code": "escape"}]}
      ]
    },
    {
      "description": "⬆ Hyper: iTerm2基本导航",
      "manipulators": [
        {"description": "Hyper + H: 左 [iTerm2]","type": "basic","from": {"key_code": "h"},"to": [{"key_code": "b","modifiers": ["left_control"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1},{"type": "frontmost_application_if","bundle_identifiers": ["com.googlecode.iterm","com.apple.Terminal"]}]},
        {"description": "Hyper + L: 右 [iTerm2]","type": "basic","from": {"key_code": "l"},"to": [{"key_code": "f","modifiers": ["left_control"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1},{"type": "frontmost_application_if","bundle_identifiers": ["com.googlecode.iterm","com.apple.Terminal"]}]},
        {"description": "Hyper + I: 行首 [iTerm2]","type": "basic","from": {"key_code": "i"},"to": [{"key_code": "a","modifiers": ["left_control"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1},{"type": "frontmost_application_if","bundle_identifiers": ["com.googlecode.iterm","com.apple.Terminal"]}]},
