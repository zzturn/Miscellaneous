{
  "title": "Capslock Enhancement",
  "url": "https://github.com/zzturn/Miscellaneous/raw/master/Karabiner/capslock.json",
  "fork_from": "https://vonng.com/capslock.json",
  "version": "20260405",
  "maintainers": ["zzturn"],
  "author": "zzturn",
  "json_url": "https://github.com/zzturn/Miscellaneous/raw/master/Karabiner/capslock.json",
  "import_url": "karabiner://karabiner/assets/complex_modifications/import?url=https://github.com/zzturn/Miscellaneous/raw/master/Karabiner/capslock.json",
  "repo": "https://github.com/zzturn/Miscellaneous/Karabiner",
  "rules": [
    {
      "description": "🔑 Hyper: 激活",
      "manipulators": [
        {"description": "CapsLock: 双击切换大写","type": "basic","from": {"key_code": "caps_lock","modifiers": {"optional": ["any"]}},"to": [{"key_code": "caps_lock","hold_down_milliseconds": 200},{"set_variable": {"name": "capslock_expiration","value": 0}}],"conditions": [{"type": "expression_if","expression": "capslock_expiration > system.now.milliseconds"}]},
        {"description": "CapsLock: 按住激活Hyper，单击Esc","type": "basic","from": {"key_code": "caps_lock","modifiers": {"optional": ["any"]}},"to": [{"set_variable": {"name": "capslock_expiration","expression": "system.now.milliseconds + 300"}},{"set_variable": {"name": "hyper_on","value": 1}}],"to_after_key_up": [{"set_variable": {"name": "hyper_on","value": 0}}],"to_delayed_action": {"to_if_invoked": [{"key_code": "escape","conditions": [{"type": "variable_unless","name": "hyper_on","value": 1}]}],"to_if_canceled": []},"parameters": {"basic.to_delayed_action_delay_milliseconds": 300}}
      ]
    },
    {
      "description": "⬆️ Hyper: 基本导航",
      "manipulators": [
        {"description": "Hyper + H: 左","type": "basic","from": {"key_code": "h"},"to": [{"key_code": "left_arrow"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + L: 右","type": "basic","from": {"key_code": "l"},"to": [{"key_code": "right_arrow"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + J: 下","type": "basic","from": {"key_code": "j"},"to": [{"key_code": "down_arrow"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + K: 上","type": "basic","from": {"key_code": "k"},"to": [{"key_code": "up_arrow"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + I: 行首","type": "basic","from": {"key_code": "i"},"to": [{"key_code": "left_arrow","modifiers": ["left_command"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + O: 行尾","type": "basic","from": {"key_code": "o"},"to": [{"key_code": "right_arrow","modifiers": ["left_command"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + U: 上翻页","type": "basic","from": {"key_code": "u"},"to": [{"key_code": "page_up"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + P: 下翻页","type": "basic","from": {"key_code": "p"},"to": [{"key_code": "page_down"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]}
      ]
    },
    {
      "description": "⬆️ Hyper: 按词导航",
      "manipulators": [
        {"description": "Hyper + ⌥H: 按词左","type": "basic","from": {"key_code": "h","modifiers": {"mandatory": ["option"]}},"to": [{"key_code": "left_arrow","modifiers": ["left_option"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌥L: 按词右","type": "basic","from": {"key_code": "l","modifiers": {"mandatory": ["option"]}},"to": [{"key_code": "right_arrow","modifiers": ["left_option"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌥J: 下×3","type": "basic","from": {"key_code": "j","modifiers": {"mandatory": ["option"]}},"to": [{"key_code": "down_arrow"},{"key_code": "down_arrow"},{"key_code": "down_arrow"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌥K: 上×3","type": "basic","from": {"key_code": "k","modifiers": {"mandatory": ["option"]}},"to": [{"key_code": "up_arrow"},{"key_code": "up_arrow"},{"key_code": "up_arrow"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]}
      ]
    },
    {
      "description": "✴️ Hyper: 选中",
      "manipulators": [
        {"description": "Hyper + ⇧H: 选左","type": "basic","from": {"key_code": "h","modifiers": {"mandatory": ["shift"]}},"to": [{"key_code": "left_arrow","modifiers": ["left_shift"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⇧L: 选右","type": "basic","from": {"key_code": "l","modifiers": {"mandatory": ["shift"]}},"to": [{"key_code": "right_arrow","modifiers": ["left_shift"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⇧J: 选下","type": "basic","from": {"key_code": "j","modifiers": {"mandatory": ["shift"]}},"to": [{"key_code": "down_arrow","modifiers": ["left_shift"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⇧K: 选上","type": "basic","from": {"key_code": "k","modifiers": {"mandatory": ["shift"]}},"to": [{"key_code": "up_arrow","modifiers": ["left_shift"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},

        {"description": "Hyper + ⇧⌥H: 按词选左","type": "basic","from": {"key_code": "h","modifiers": {"mandatory": ["shift","option"]}},"to": [{"key_code": "left_arrow","modifiers": ["left_option","left_shift"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⇧⌥L: 按词选右","type": "basic","from": {"key_code": "l","modifiers": {"mandatory": ["shift","option"]}},"to": [{"key_code": "right_arrow","modifiers": ["left_option","left_shift"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⇧⌥J: 选下×3","type": "basic","from": {"key_code": "j","modifiers": {"mandatory": ["shift","option"]}},"to": [{"key_code": "down_arrow","modifiers": ["left_shift"]},{"key_code": "down_arrow","modifiers": ["left_shift"]},{"key_code": "down_arrow","modifiers": ["left_shift"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⇧⌥K: 选上×3","type": "basic","from": {"key_code": "k","modifiers": {"mandatory": ["shift","option"]}},"to": [{"key_code": "up_arrow","modifiers": ["left_shift"]},{"key_code": "up_arrow","modifiers": ["left_shift"]},{"key_code": "up_arrow","modifiers": ["left_shift"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]}
      ]
    },
    {
      "description": "🗑️ Hyper: 删除",
      "manipulators": [
        {"description": "Hyper + M: 删前","type": "basic","from": {"key_code": "m"},"to": [{"key_code": "delete_or_backspace"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ,: 删后","type": "basic","from": {"key_code": "comma"},"to": [{"key_code": "delete_forward"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + N: 删前词","type": "basic","from": {"key_code": "n"},"to": [{"key_code": "delete_or_backspace","modifiers": ["left_option"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + .: 删后词","type": "basic","from": {"key_code": "period"},"to": [{"key_code": "delete_forward","modifiers": ["left_option"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌘N: 删至行首","type": "basic","from": {"key_code": "n","modifiers": {"mandatory": ["command"]}},"to": [{"key_code": "left_arrow","modifiers": ["left_shift","left_command"]},{"key_code": "delete_or_backspace"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌘.: 删至行尾","type": "basic","from": {"key_code": "period","modifiers": {"mandatory": ["command"]}},"to": [{"key_code": "right_arrow","modifiers": ["left_shift","left_command"]},{"key_code": "delete_or_backspace"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]}
      ]
    },
    {
      "description": "🌐 Hyper: 输入法",
      "manipulators": [
        {"description": "Hyper + Space: 输入法","type": "basic","from": {"key_code": "spacebar"},"to": [{"key_code": "spacebar","modifiers": ["left_control"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌘Space: 表情","type": "basic","from": {"key_code": "spacebar","modifiers": {"mandatory": ["command"]}},"to": [{"key_code": "spacebar","modifiers": ["left_control","left_command"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + Esc: CapsLock","type": "basic","from": {"key_code": "escape","modifiers": {"optional": ["caps_lock"]}},"to": [{"key_code": "caps_lock","modifiers": ["left_control"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]}
      ]
    },
    {
      "description": "🔲 Hyper: 窗口",
      "manipulators": [
        {"description": "Hyper + A: Dock","type": "basic","from": {"key_code": "a"},"to": [{"key_code": "d","modifiers": ["left_option","left_command"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌘A: Expose","type": "basic","from": {"key_code": "a","modifiers": {"mandatory": ["command"]}},"to": [{"key_code": "up_arrow","modifiers": ["left_control"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌥A: 桌面","type": "basic","from": {"key_code": "a","modifiers": {"mandatory": ["option"]}},"to": [{"key_code": "f11"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌃A: Launchpad","type": "basic","from": {"key_code": "a","modifiers": {"mandatory": ["control"]}},"to": [{"shell_command": "open -a 'Launchpad'"}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⇧A: 通知中心","type": "basic","from": {"key_code": "a","modifiers": {"mandatory": ["shift"]}},"to": [{"key_code": "n","modifiers": ["fn"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + S: Tab 切换","type": "basic","from": {"key_code": "s"},"to": [{"key_code": "tab","modifiers": ["left_control"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌘S: Tab 切换(反向)","type": "basic","from": {"key_code": "s","modifiers": {"mandatory": ["command"]}},"to": [{"key_code": "tab","modifiers": ["left_control","left_shift"]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]}
      ]
    },
    {
      "description": "⚡ Hyper: 应用",
      "manipulators": [
        {"description": "Hyper + Z: 切回上一个应用","type": "basic","from": {"key_code": "z"},"to": [{"software_function": {"open_application": {"frontmost_application_history_index": 1}}}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + Q: 活动监视器","type": "basic","from": {"key_code": "q"},"to": [{"software_function": {"open_application": {"bundle_identifier": "com.apple.ActivityMonitor"}},"conditions": [{"type": "frontmost_application_unless","bundle_identifiers": ["com.apple.ActivityMonitor"]}]},{"key_code": "h","modifiers": ["left_command"],"conditions": [{"type": "frontmost_application_if","bundle_identifiers": ["com.apple.ActivityMonitor"]}]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌘Q: 系统设置","type": "basic","from": {"key_code": "q","modifiers": {"mandatory": ["command"]}},"to": [{"software_function": {"open_application": {"bundle_identifier": "com.apple.systempreferences"}},"conditions": [{"type": "frontmost_application_unless","bundle_identifiers": ["com.apple.systempreferences"]}]},{"key_code": "h","modifiers": ["left_command"],"conditions": [{"type": "frontmost_application_if","bundle_identifiers": ["com.apple.systempreferences"]}]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},

        {"description": "Hyper + W: 微信","type": "basic","from": {"key_code": "w"},"to": [{"software_function": {"open_application": {"bundle_identifier": "com.tencent.xinWeChat"}},"conditions": [{"type": "frontmost_application_unless","bundle_identifiers": ["com.tencent.xinWeChat"]}]},{"key_code": "h","modifiers": ["left_command"],"conditions": [{"type": "frontmost_application_if","bundle_identifiers": ["com.tencent.xinWeChat"]}]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌘W: iMessage","type": "basic","from": {"key_code": "w","modifiers": {"mandatory": ["command"]}},"to": [{"software_function": {"open_application": {"bundle_identifier": "com.apple.MobileSMS"}},"conditions": [{"type": "frontmost_application_unless","bundle_identifiers": ["com.apple.MobileSMS"]}]},{"key_code": "h","modifiers": ["left_command"],"conditions": [{"type": "frontmost_application_if","bundle_identifiers": ["com.apple.MobileSMS"]}]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},
        {"description": "Hyper + ⌥W: Telegram","type": "basic","from": {"key_code": "w","modifiers": {"mandatory": ["option"]}},"to": [{"software_function": {"open_application": {"bundle_identifier": "ru.keepcoder.Telegram"}},"conditions": [{"type": "frontmost_application_unless","bundle_identifiers": ["ru.keepcoder.Telegram"]}]},{"key_code": "h","modifiers": ["left_command"],"conditions": [{"type": "frontmost_application_if","bundle_identifiers": ["ru.keepcoder.Telegram"]}]}],"conditions": [{"type": "variable_if","name": "hyper_on","value": 1}]},

